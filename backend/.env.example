# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | claude-cli | ollama
LLM_PROVIDER=anthropic

# ── Anthropic API (LLM_PROVIDER=anthropic) ───────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Claude CLI (LLM_PROVIDER=claude-cli) ─────────────────────────────────────
# Requires `claude` CLI installed and authenticated: https://claude.ai/code
# CLAUDE_CLI_PATH=claude
# CLAUDE_CLI_TIMEOUT=120

# ── Ollama (LLM_PROVIDER=ollama) ─────────────────────────────────────────────
# Requires Ollama running locally: https://ollama.ai
# Pull a model first: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT=120

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./exams_analyzer.db
